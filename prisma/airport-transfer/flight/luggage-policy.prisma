
model AirportTransferLuggagePolicy {
    id String @id @default(cuid())

    transferId String @unique

    transfer AirportTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

    checkedBaggage Int?

    cabinBaggage Int?

    oversizedAllowed Boolean?

    oversizedFee Float?

    sportsEquipmentAllowed Boolean?

    strollerAllowed Boolean?

    wheelchairAllowed Boolean?

    createdAt DateTime @default(now())
}