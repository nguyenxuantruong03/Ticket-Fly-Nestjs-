
model AirportTransferWaitingPolicy {
    id String @id @default(cuid())

    transferId String @unique

    transfer AirportTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

    freeWaitingMinutes Int?

    airportFreeWaitingMinutes Int?

    waitingFeePerHour Float?

    maximumWaitingMinutes Int?

    createdAt DateTime @default(now())
}