model AirportTransferPrice {
    id String @id @default(cuid())

    transferId String @unique

    transfer AirportTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

    currency Currency

    fromPrice Float

    toPrice Float?

    originalFromPrice Float?

    originalToPrice Float?

    routePrices AirportTransferRoutePrice[]

    tripPrices AirportTransferTripPrice[]

    rules AirportTransferPriceRule[]

    createdAt DateTime @default(now())

    updatedAt DateTime @updatedAt
}
