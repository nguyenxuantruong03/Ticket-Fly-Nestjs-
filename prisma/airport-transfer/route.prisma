model AirportTransferRoute {
    id String @id @default(cuid())

    transferId String

    transfer AirportTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

    type               AirportTransferRouteType
    prices             AirportTransferRoutePrice[]
    departureAddressId String

    departureAddress Address @relation("AirportTransferDepartureAddress", fields: [departureAddressId], references: [id])

    arrivalAddressId String

    arrivalAddress Address @relation("AirportTransferArrivalAddress", fields: [arrivalAddressId], references: [id])

    distanceKm Float?

    estimatedDuration Int?

    trips AirportTransferTrip[]

    stops AirportTransferRouteStop[]

    active Boolean @default(true)

    createdAt DateTime @default(now())

    updatedAt DateTime @updatedAt

    @@index([transferId])
    @@index([type])
}

model AirportTransferRouteStop {
    id String @id @default(cuid())

    routeId String

    route AirportTransferRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)

    addressId String

    address Address @relation(fields: [addressId], references: [id])

    stopOrder Int

    estimatedArrival Int?

    waitingMinutes Int?

    createdAt DateTime @default(now())

    @@unique([routeId, stopOrder])
    @@index([routeId])
}

model AirportTransferSchedule {
    id String @id @default(cuid())

    transferId String

    transfer AirportTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

    departureTime String

    operatingDays Weekday[]

    startDate DateTime

    endDate DateTime?

    active Boolean @default(true)

    trips AirportTransferTrip[]

    createdAt DateTime @default(now())

    updatedAt DateTime @updatedAt
}
