
model AirportTransferRatingSummary {
    id String @id @default(cuid())

    transferId String @unique

    transfer AirportTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

    averageRating Float @default(0)

    totalReviews Int @default(0)

    driverRating Float @default(0)

    vehicleRating Float @default(0)

    punctuality Float @default(0)

    cleanliness Float @default(0)

    communication Float @default(0)

    pickupExperience Float @default(0)

    valueForMoney Float @default(0)

    safety Float @default(0)

    comfort Float @default(0)

    fiveStar Int @default(0)

    fourStar Int @default(0)

    threeStar Int @default(0)

    twoStar Int @default(0)

    oneStar Int @default(0)

    updatedAt DateTime @updatedAt
}
