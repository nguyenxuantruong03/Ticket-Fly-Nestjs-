
model AirportTransferVehicleAvailability {
    id String @id @default(cuid())

    vehicleId String

    vehicle AirportTransferVehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

    startDate DateTime

    endDate DateTime

    available Boolean

    note String?

    createdAt DateTime @default(now())

    @@index([vehicleId])
    @@index([startDate])
    @@index([endDate])
}