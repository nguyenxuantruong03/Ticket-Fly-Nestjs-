model AirportTransferTrip {
    id String @id @default(cuid())

    transferId String

    transfer AirportTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

    routeId String

    route AirportTransferRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)

    scheduleId String?

    schedule      AirportTransferSchedule? @relation(fields: [scheduleId], references: [id])
    bookings      AirportTransferBooking[]
    departureTime DateTime

    estimatedArrivalTime DateTime

    totalSeats Int

    availableSeats    Int
    price             AirportTransferTripPrice?
    status            AirportTransferTripStatus          @default(scheduled)
    locks             AirportTransferInventoryLock[]
    vehicleAssignment AirportTransferVehicleAssignment[]

    createdAt DateTime @default(now())

    updatedAt DateTime @updatedAt

    @@index([routeId])
    @@index([departureTime])
    @@index([status])
}