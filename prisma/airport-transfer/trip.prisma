model AirportTransferTrip {
    id String @id @default(cuid())

    transferId String

    transfer AirportTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

    routeId String

    route AirportTransferRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)

    scheduleId String?

    schedule      AirportTransferSchedule? @relation(fields: [scheduleId], references: [id])
    bookings      AirportTransferBooking[]
    departureTime DateTime

    estimatedArrivalTime DateTime

    totalSeats Int

    availableSeats    Int
    price             AirportTransferTripPrice?
    status            AirportTransferTripStatus          @default(scheduled)
    locks             AirportTransferInventoryLock[]
    vehicleAssignment AirportTransferVehicleAssignment[]

    createdAt DateTime @default(now())

    updatedAt DateTime @updatedAt

    @@index([routeId])
    @@index([departureTime])
    @@index([status])
}

model AirportTransferAvailabilityCalendar {
    id String @id @default(cuid())

    availabilityId String

    availability AirportTransferAvailability @relation(fields: [availabilityId], references: [id], onDelete: Cascade)

    date DateTime

    available Boolean

    totalVehicles Int

    remainingVehicles Int

    stopSell Boolean @default(false)

    minimumNoticeMinutes Int?

    createdAt DateTime @default(now())

    @@unique([availabilityId, date])
    @@index([date])
}

model AirportTransferInventoryLock {
    id String @id @default(cuid())

    availabilityId String
    availability   AirportTransferAvailability @relation(fields: [availabilityId], references: [id], onDelete: Cascade)

    tripId String?
    trip   AirportTransferTrip? @relation(fields: [tripId], references: [id])

    vehicleId String?
    vehicle   AirportTransferVehicle? @relation(fields: [vehicleId], references: [id])

    bookingId String?
    booking   AirportTransferBooking? @relation(fields: [bookingId], references: [id], onDelete: Cascade)

    userId String
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    startTime  DateTime
    releasedAt DateTime?
    status     InventoryLockStatus @default(locked)
    endTime    DateTime
    quantity   Int
    expiresAt  DateTime

    createdAt DateTime @default(now())

    @@index([expiresAt])
}

model AirportTransferBlackoutDate {
    id String @id @default(cuid())

    availabilityId String

    availability AirportTransferAvailability @relation(fields: [availabilityId], references: [id], onDelete: Cascade)

    date DateTime

    reason String?

    createdAt DateTime @default(now())

    @@index([date])
}

model AirportTransferVehicleAssignment {
    id String @id @default(cuid())

    tripId String

    trip AirportTransferTrip @relation(fields: [tripId], references: [id], onDelete: Cascade)

    vehicleId String

    vehicle AirportTransferVehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

    driverId String?

    driver AirportTransferDriver? @relation(fields: [driverId], references: [id])

    assignedAt DateTime @default(now())

    @@unique([tripId, vehicleId])
}

model AirportTransferCapacity {
    id String @id @default(cuid())

    transferId String @unique

    transfer AirportTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

    maxTripsPerDay Int?

    maxVehiclesPerDay Int?

    overbookingAllowed Boolean @default(false)
}

model AirportTransferAvailability {
    id String @id @default(cuid())

    transferId String @unique

    transfer AirportTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

    available Boolean @default(true)

    calendars AirportTransferAvailabilityCalendar[]

    locks AirportTransferInventoryLock[]

    blackoutDates AirportTransferBlackoutDate[]

    updatedAt DateTime @updatedAt

    createdAt DateTime @default(now())
}
