model AirportTransferPrice {
    id String @id @default(cuid())

    transferId String @unique

    transfer AirportTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

    currency Currency

    fromPrice Float

    toPrice Float?

    originalFromPrice Float?

    originalToPrice Float?

    routePrices AirportTransferRoutePrice[]

    tripPrices AirportTransferTripPrice[]

    rules AirportTransferPriceRule[]

    createdAt DateTime @default(now())

    updatedAt DateTime @updatedAt
}


model AirportTransferRoutePrice {

    id String @id @default(cuid())

    priceId String
    price AirportTransferPrice   @relation(fields: [priceId], references: [id], onDelete: Cascade)

    routeId String
    route AirportTransferRoute    @relation(fields: [routeId], references: [id], onDelete: Cascade)
    
    vehicleType AirportTransferVehicleType

    basePrice Float

    originalPrice Float?

    breakdown AirportTransferPriceBreakdown?

    @@unique([routeId, vehicleType])

}

model AirportTransferTripPrice {

    id String @id @default(cuid())

    priceId String
    price AirportTransferPrice    @relation(fields: [priceId], references: [id], onDelete: Cascade)

    tripId String @unique
    trip AirportTransferTrip  @relation(fields: [tripId], references: [id], onDelete: Cascade)

    finalPrice Float
    originalPrice Float?

}

model AirportTransferPriceBreakdown {

    id String @id @default(cuid())

    routePriceId String @unique

    routePrice AirportTransferRoutePrice    @relation(fields: [routePriceId], references: [id], onDelete: Cascade)

    baseFare Float

    airportFee Float @default(0)

    parkingFee Float @default(0)

    tollFee Float @default(0)

    serviceFee Float @default(0)

    taxes Float @default(0)

    discount Float @default(0)

    totalPrice Float

    includedItems String[] @default([])

    extraFees AirportTransferExtraFee[]

}

model AirportTransferExtraFee {

    id String @id @default(cuid())

    breakdownId String

    breakdown AirportTransferPriceBreakdown   @relation(fields: [breakdownId], references: [id], onDelete: Cascade)

    type AirportTransferExtraFeeType

    name String

    amount Float

    required Boolean @default(false)

}

model AirportTransferPriceRule {

    id String @id @default(cuid())

    priceId String

    price AirportTransferPrice     @relation(fields: [priceId], references: [id], onDelete: Cascade)

    name String

    type AirportTransferPriceRuleType

    adjustmentType AirportTransferAdjustmentType

    value Float

    minimumSpend Float?

    maximumDiscount Float?

    couponCode String?

    validFrom DateTime?

    validTo DateTime?

    priority Int @default(0)

    combinable Boolean @default(false)

    active Boolean @default(true)

    createdAt DateTime @default(now())

    updatedAt DateTime @updatedAt

}