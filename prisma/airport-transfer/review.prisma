model AirportTransferReview {
    id String @id @default(cuid())

    transferId String
    transfer   AirportTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

    bookingId String?
    booking   AirportTransferBooking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

    userId String?
    user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

    overallRating Float

    driverRating Float?

    vehicleRating Float?

    punctuality Float?

    cleanliness Float?

    communication Float?

    pickupExperience Float?

    valueForMoney Float?

    safety Float?

    comfort Float?

    title String?

    comment String

    pros String?

    cons String?

    recommend Boolean?

    verified Boolean @default(false)

    status ReviewStatus @default(pending)

    travelDate DateTime?

    helpfulCount Int @default(0)

    response String?

    responseAt DateTime?

    images AirportTransferReviewImage[]

    createdAt DateTime @default(now())

    updatedAt DateTime @updatedAt

    @@unique([bookingId])
    @@index([transferId])
    @@index([overallRating])
    @@index([verified])
    @@index([status])
}

model AirportTransferReviewImage {
    id String @id @default(cuid())

    reviewId String

    review AirportTransferReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)

    url String

    createdAt DateTime @default(now())
}

model AirportTransferRatingSummary {
    id String @id @default(cuid())

    transferId String @unique

    transfer AirportTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

    averageRating Float @default(0)

    totalReviews Int @default(0)

    driverRating Float @default(0)

    vehicleRating Float @default(0)

    punctuality Float @default(0)

    cleanliness Float @default(0)

    communication Float @default(0)

    pickupExperience Float @default(0)

    valueForMoney Float @default(0)

    safety Float @default(0)

    comfort Float @default(0)

    fiveStar Int @default(0)

    fourStar Int @default(0)

    threeStar Int @default(0)

    twoStar Int @default(0)

    oneStar Int @default(0)

    updatedAt DateTime @updatedAt
}
