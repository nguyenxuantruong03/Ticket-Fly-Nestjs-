    trip YachtTrip @relation(fields: [tripId], references: [id], onDelete: Cascade)

    repeatType YachtRepeatType

    daysOfWeek Int[]

    startDate DateTime?

    endDate DateTime?

    departureTime String?
}

model YachtTripPrice {
    id String @id @default(cuid())

    tripId String    @unique
    trip   YachtTrip @relation(fields: [tripId], references: [id], onDelete: Cascade)

    amount Float

    originalAmount Float?

    tax Float @default(0)

    serviceFee Float @default(0)

    discount Float @default(0)

    finalAmount Float

    createdAt DateTime @default(now())
}

model YachtTrip {
    id String @id @default(cuid())

    yachtId String
    yacht   Yacht  @relation(fields: [yachtId], references: [id], onDelete: Cascade)

    routeId       String?
    route         YachtRoute?    @relation(fields: [routeId], references: [id])
    bookings      YachtBooking[]
    departureTime DateTime

    arrivalTime DateTime

    status YachtTripStatus @default(active)

    maxGuests Int?

    schedule  YachtSchedule?
    price     YachtTripPrice?
    locks     YachtInventoryLock[]
    createdAt DateTime             @default(now())

    updatedAt DateTime @updatedAt

    @@index([departureTime])
    @@index([status])
}

model YachtCapacity {
    id String @id @default(cuid())

    vehicleId String       @unique
    vehicle   YachtVehicle @relation(fields: [vehicleId], references: [id])

    guestCapacity Int

    overnightCapacity Int?

    cabinCount Int?

    bathroomCount Int?

    crewCapacity Int?
}

model YachtSpecification {
    id String @id @default(cuid())

    vehicleId String @unique

    vehicle YachtVehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

    enginePowerHp Int?

    cruisingSpeedKnots Float?

    maxSpeedKnots Float?

    fuelCapacityLiter Float?

    rangeNm Float?
}

model YachtVehicleImage {
    id String @id @default(cuid())

    vehicleId String

    vehicle YachtVehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

    url String

    category YachtImageCategory

    isPrimary Boolean @default(false)

    sortOrder Int @default(0)

    createdAt DateTime @default(now())
}

model YachtVehicle {
    id String @id @default(cuid())

    yachtId String @unique

    yacht Yacht @relation(fields: [yachtId], references: [id], onDelete: Cascade)

    name String?

    manufacturer String?

    model String?

    year Int?

    registrationNumber String?

    lengthMeter Float?

    widthMeter Float?

    speedKnots Float?

    fuelType YachtFuelType?

    condition YachtCondition?

    capacity        YachtCapacity?
    facilities      YachtVehicleFacilities?
    specification   YachtSpecification?
    images          YachtVehicleImage[]
    safetyEquipment YachtSafetyEquipment?
    createdAt       DateTime                @default(now())

    updatedAt DateTime @updatedAt
}

