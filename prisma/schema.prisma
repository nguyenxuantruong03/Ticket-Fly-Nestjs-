    threeStarCount Int @default(0)

    twoStarCount Int @default(0)

    oneStarCount Int @default(0)

    // =====================================================
    // BOOKING STATISTICS
    // =====================================================

    totalBookings Int @default(0)

    completedBookings Int @default(0)

    cancelledBookings Int @default(0)

    totalCustomers Int @default(0)

