model Address {
    id                 String  @id @default(cuid())
    // ======================================================
    // ADDRESS
    // ======================================================
    name               String?
    houseNumber        String?
    street             String?
    ward               String?
    district           String?
    administrativeArea String?
    region             String?
    postcode           String?
    countryCode        String
    cityId             String
    city               City    @relation(fields: [cityId], references: [id], onDelete: Restrict)

    // ======================================================
    // MAP
    // ======================================================
    latitude          Float?
    longitude         Float?
    timezone          String?
    plusCode          String?
    precision         AddressPrecision   @default(ADDRESS)
    // ======================================================
    // RELATIONS
    // ======================================================
    hotelInformations HotelInformation[]

    airport FlyAirport[]

    busRouteStop                   BusRouteStop[]
    busBoardingPoint               BusBoardingPoint[]
    busDropoffPoint                BusDropoffPoint[]
    yachtRouteStop                 YachtRouteStop[]
    yachtMarina                    YachtMarina[]
    yachtBookingPickups            YachtBookingPickup[]
    departureBusRoutes             BusRoute[]                @relation("BusDepartureAddress")
    arrivalBusRoutes               BusRoute[]                @relation("BusArrivalAddress")
    departureAirportTransferRoutes AirportTransferRoute[]    @relation("AirportTransferDepartureAddress")
    arrivalAirportTransferRoutes   AirportTransferRoute[]    @relation("AirportTransferArrivalAddress")
    carRentalLocations             CarRentalLocation[]
    carRentalVehicleLocation       CarRentalVehicleLocation?

    airportTransferRouteStop AirportTransferRouteStop[]
    hotelNearbyPlace         HotelNearbyPlace?
    providerBooking          ProviderBooking?
    // ======================================================
    // TIMESTAMP
    // ======================================================
    createdAt                DateTime                   @default(now())
    updatedAt                DateTime                   @updatedAt
}

enum AddressPrecision {
    COUNTRY
    CITY
    DISTRICT
    STREET
    ADDRESS
    POINT
}

// ======================================================
// CITY
// ======================================================

model City {
    id String @id @default(cuid())
    // =========================
    // BASIC
    // =========================

    name             String
    nativeName       String?
    slug             String  @unique
    code             String? @unique
    iataCode         String? @unique
    subtitle         String?
    shortDescription String?
    description      String?

    // =========================
    // COUNTRY
    // =========================

    countryId          String
    country            Country @relation(fields: [countryId], references: [id], onDelete: Restrict)
    administrativeArea String?
    region             String?
    isCapital          Boolean @default(false)

    // =========================
    // LOCATION
    // =========================

    latitude  Float?
    longitude Float?
    elevation Float?
    timezone  String?
    utcOffset String?

    // =========================
    // SEARCH
    // =========================

    priority        Int      @default(0)
    displayOrder    Int      @default(0)
    popularityScore Float    @default(0)
    featured        Boolean  @default(false)
    popular         Boolean  @default(false)
    searchable      Boolean  @default(true)
    aliases         String[]
    keywords        String[]
    tags            String[]

    // =========================
    // MEDIA
    // =========================

    thumbnail   String?
    coverImage  String?
    bannerImage String?
    images      String[]
    video       String?

    // =========================
    // TRAVEL
    // =========================

    bestMonths  String[]
    rainyMonths String[]

    // =========================
    // SEO
    // =========================

    seoTitle       String?
    seoDescription String?
    seoKeywords    String[]

    // =========================
    // STATUS
    // =========================

    verified Boolean    @default(false)
    status   CityStatus @default(ACTIVE)

    // =========================
    // RELATIONS
    // =========================

    addresses Address[]

    // Future
    // tours Tour[]
    // activities Activity[]
    // restaurants Restaurant[]

    // =========================
    // TIMESTAMP
    // =========================

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

// ======================================================
// ENUMS
// ======================================================

enum CityStatus {
    ACTIVE
    HIDDEN
    COMING_SOON
    DISABLED
}

enum Continent {
    AFRICA
    ANTARCTICA
    ASIA
    EUROPE
    NORTH_AMERICA
    SOUTH_AMERICA
    OCEANIA
}

// ======================================================
// COUNTRY
// ======================================================

model Country {
    id String @id @default(cuid())

    // =========================
    // BASIC
    // =========================

    name String

    officialName String?

    slug String @unique

    code String @unique // VN

    iso2 String @unique // VN

    iso3 String @unique // VNM

    phoneCode String? // +84

    capital String?

    // =========================
    // LOCATION
    // =========================

    continent Continent

    timezone String?

    languages String[]

    // =========================
    // MEDIA
    // =========================

    flag String?

    thumbnail String?

    coverImage String?

    // =========================
    // SEARCH
    // =========================

    aliases String[]

    keywords String[]

    priority Int @default(0)

    featured Boolean @default(false)

    searchable Boolean @default(true)

    // =========================
    // STATUS
    // =========================

    active Boolean @default(true)

    // =========================
    // RELATIONS
    // =========================

    cities City[]

    currencyId String
    currency   Currency? @relation(fields: [currencyId], references: [id])
