model FlyBooking {
    id String @id @default(cuid())

    bookingNumber String @unique

    userId String?
    user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

    contact FlyBookingContact?

    passengers FlyPassenger[]

    statusHistory FlyBookingStatusHistory[]

    status FlyBookingStatus @default(pending)

    totalPassengers Int

    totalAmount Float

    currency Currency

    note              String?
    interlines        FlyInterline[]
    itineraries       FlyItinerary[]
    seatInventoryLock FlySeatInventoryLock[]
    FlyInventoryLock  FlyInventoryLock[]
    waitlist          FlyWaitlist[]
    createdAt         DateTime               @default(now())

    updatedAt DateTime @updatedAt

    @@index([bookingNumber])
    @@index([userId])
}

model FlyBookingContact {
    id String @id @default(cuid())

    bookingId String     @unique
    booking   FlyBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

    fullName String

    email String

    phone String

    countryCode String?
}

model FlyPassenger {
    id String @id @default(cuid())

    bookingId String
    booking   FlyBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

    type PassengerType

    title PassengerTitle?

    firstName String

    lastName String

    gender Gender?

    birthday DateTime?

    nationality String?

    document FlyPassengerDocument?

    seat FlySeatAssignment?

    meal FlyMealSelection?

    baggage FlyExtraBaggage[]

    tickets            FlyTicket[]
    wifi               FlyPassengerWifi[]
    priorityBoarding   FlyPriorityBoarding[]
    lounge             FlyPassengerLounge[]
    fastTrack          FlyFastTrack[]
    passengerInsurance FlyPassengerInsurance[]
    passengerAddon     FlyPassengerAddon[]
    createdAt          DateTime                @default(now())

    @@index([bookingId])
}

model FlyPassengerDocument {
    id String @id @default(cuid())

    passengerId String       @unique
    passenger   FlyPassenger @relation(fields: [passengerId], references: [id], onDelete: Cascade)

    passportNumber String?

    passportCountry String?

    expiryDate DateTime?

    nationalId String?
}

model FlyTicket {
    id          String @id @default(cuid())
    passengerId String

    passenger FlyPassenger @relation(fields: [passengerId], references: [id], onDelete: Cascade)

    ticketNumber String @unique

    pnr String?

    qrCode String?

    issuedAt DateTime?

    boardingPass FlyBoardingPass?

    createdAt DateTime @default(now())
}

model FlyBoardingPass {
    id String @id @default(cuid())

    ticketId String @unique

    ticket FlyTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

    gate String?

    boardingTime DateTime?

    boardingGroup String?

    barcode String?
}

model FlyBookingStatusHistory {
    id String @id @default(cuid())

    bookingId String

    booking FlyBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

    fromStatus FlyBookingStatus?

    toStatus FlyBookingStatus

    note String?

    createdAt DateTime @default(now())
}

model FlySeatAssignment {
    id String @id @default(cuid())

    passengerId String       @unique
    passenger   FlyPassenger @relation(fields: [passengerId], references: [id], onDelete: Cascade)

    seatId String
    seat   FlySeat @relation(fields: [seatId], references: [id], onDelete: Restrict)

    paid Boolean @default(false)

    amount Float?

    currency Currency?

    assignedAt DateTime @default(now())

    @@unique([seatId])
}

model FlyMealSelection {
    id String @id @default(cuid())

    passengerId String @unique

    passenger FlyPassenger @relation(fields: [passengerId], references: [id], onDelete: Cascade)

    mealId String

    meal FlyMeal @relation(fields: [mealId], references: [id], onDelete: Restrict)

    quantity Int @default(1)

    amount Float?

    currency Currency?
}

model FlyMeal {
    id String @id @default(cuid())

    airlineId String

    airline FlyAirline @relation(fields: [airlineId], references: [id], onDelete: Cascade)

    name String

    description String?

    type FlyMealType

    image String?

    price Float?

    currency   Currency?
    selections FlyMealSelection[]
    active     Boolean            @default(true)
}

model FlyExtraBaggage {
    id String @id @default(cuid())

    passengerId String

    passenger FlyPassenger @relation(fields: [passengerId], references: [id], onDelete: Cascade)

    weightKg Float

    amount Float

    currency Currency
}

model FlyLounge {
    id String @id @default(cuid())

    airportId String

    airport FlyAirport @relation(fields: [airportId], references: [id], onDelete: Cascade)

    name String

    description String?

    image String?

    price      Float?
    passengers FlyPassengerLounge[]
    currency   Currency?
}

model FlyPassengerLounge {
    id String @id @default(cuid())

    passengerId String       @unique
    passenger   FlyPassenger @relation(fields: [passengerId], references: [id], onDelete: Cascade)

    loungeId String
    lounge   FlyLounge @relation(fields: [loungeId], references: [id], onDelete: Restrict)

    amount Float?

    currency Currency?
}

model FlyInsurance {
    id String @id @default(cuid())

    airlineId String?
    airline   FlyAirline? @relation(fields: [airlineId], references: [id], onDelete: Restrict)

    provider String

    name String

    description String?

    coverage String?

    amount Float

    currency Currency

    active Boolean @default(true)

    passengers FlyPassengerInsurance[]
}

model FlyPassengerInsurance {
    id String @id @default(cuid())

    passengerId String
    passenger   FlyPassenger @relation(fields: [passengerId], references: [id], onDelete: Cascade)

    insuranceId String
    insurance   FlyInsurance @relation(fields: [insuranceId], references: [id], onDelete: Restrict)

    quantity Int @default(1)

    unitPrice Float

    totalPrice Float

    currency Currency

    createdAt DateTime @default(now())

    @@unique([passengerId, insuranceId])
}

model FlyPriorityBoarding {
    id String @id @default(cuid())

    passengerId String @unique

    passenger FlyPassenger @relation(fields: [passengerId], references: [id], onDelete: Cascade)

    enabled Boolean

    amount Float?

    currency Currency?
}

model FlyFastTrack {
    id String @id @default(cuid())

    passengerId String @unique

    passenger FlyPassenger @relation(fields: [passengerId], references: [id], onDelete: Cascade)

    enabled Boolean

    amount Float?

    currency Currency?
}

model FlyPassengerWifi {
    id String @id @default(cuid())

    passengerId String
    passenger   FlyPassenger @relation(fields: [passengerId], references: [id], onDelete: Cascade)

    packageId String
    package   FlyWifiPackage @relation(fields: [packageId], references: [id], onDelete: Restrict)
}
