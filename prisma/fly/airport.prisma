model FlyAirport {
    id String @id @default(cuid())

    name String

    code String @unique

    iataCode String @unique

    icaoCode String?

    city String

    country String

    terminalCount Int?

    timezone String?

    lat Float?

    lng Float?

    addressId String?

    address Address? @relation(fields: [addressId], references: [id], onDelete: SetNull)

    departures FlyRoute[] @relation("FlyDepartureAirport")

    arrivals FlyRoute[] @relation("FlyArrivalAirport")

    departureSegments FlyRouteSegment[] @relation("SegmentDepartureAirport")

    arrivalSegments       FlyRouteSegment[]          @relation("SegmentArrivalAirport")
    diversions            FlyDiversion[]
    lounge                FlyLounge[]
    minimumConnectionTime FlyMinimumConnectionTime[]
    createdAt             DateTime                   @default(now())

    updatedAt DateTime @updatedAt
}
