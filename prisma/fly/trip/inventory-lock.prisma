

model FlyInventoryLock {
    id String @id @default(cuid())

    inventoryFareId String
    inventoryFare   FlyInventoryFare @relation(fields: [inventoryFareId], references: [id], onDelete: Cascade)

    bookingId String?
    booking   FlyBooking? @relation(fields: [bookingId], references: [id], onDelete: Cascade)

    userId String?
    user   User?   @relation(fields: [userId], references: [id])

    startTime  DateTime
    releasedAt DateTime?
    status     InventoryLockStatus @default(locked)
    endTime    DateTime
    quantity   Int
    expiresAt  DateTime
    createdAt  DateTime            @default(now())
}
