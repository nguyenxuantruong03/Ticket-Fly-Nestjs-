model FlyAddon {
  id String @id @default(cuid())

  airlineId String?

  airline FlyAirline? @relation(fields: [airlineId], references: [id], onDelete: Cascade)

  name String

  description String?

  type FlyAddonType

  provider String?

  image String?

  amount Float

  active Boolean @default(true)

  passengerAddons FlyPassengerAddon[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([type])
}

model FlyPassengerAddon {
  id String @id @default(cuid())

  passengerId String

  passenger FlyPassenger @relation(fields: [passengerId], references: [id], onDelete: Cascade)

  addonId String

  addon FlyAddon @relation(fields: [addonId], references: [id], onDelete: Restrict)

  quantity Int @default(1)

  unitPrice Float

  totalPrice Float


  metadata Json?

  createdAt DateTime @default(now())

  @@index([passengerId])
  @@index([addonId])
}
