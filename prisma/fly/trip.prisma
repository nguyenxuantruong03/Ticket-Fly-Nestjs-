model FlyTrip {
    id String @id @default(cuid())

    flyId String
    fly   Fly    @relation(fields: [flyId], references: [id], onDelete: Cascade)

    routeId String
    route   FlyRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)

    flightNumber String

    departureTime DateTime

    arrivalTime DateTime

    durationMinutes Int

    status FlyTripStatus @default(scheduled)

    availableSeats Int?

    aircraftId String?

    aircraft FlyAircraft? @relation(fields: [aircraftId], references: [id], onDelete: SetNull)

    scheduleId String?

    schedule  FlySchedule?           @relation(fields: [scheduleId], references: [id])
    seatLocks FlySeatInventoryLock[]
    inventory FlyInventory?
    operation FlyOperation?
    tracking  FlyTracking[]

    cancellation FlyCancellation?

    diversion  FlyDiversion?
    codeshares FlyCodeshare[]

    firstConnections FlyConnection[] @relation("FirstConnection")

    secondConnections FlyConnection[]       @relation("SecondConnection")
    crewSchedule      FlyCrewSchedule[]
    crewAssignment    FlyCrewAssignment[]
    history           FlyTripHistory[]
    itinerarySegment  FlyItinerarySegment[]
    createdAt         DateTime              @default(now())

    updatedAt DateTime @updatedAt

    @@index([routeId])
    @@index([departureTime])
    @@index([flightNumber])
}

model FlyInventory {
    id String @id @default(cuid())

    tripId String  @unique
    trip   FlyTrip @relation(fields: [tripId], references: [id], onDelete: Cascade)

    crewAssignments FlyCrewAssignment[]
    cabins          FlyCabinInventory[]

    createdAt DateTime @default(now())

    updatedAt DateTime @updatedAt
}

model FlyCabinInventory {
    id String @id @default(cuid())

    inventoryId String

    inventory FlyInventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)

    cabinClass FlyCabinClass

    totalSeats Int

    availableSeats Int

    reservedSeats Int

    blockedSeats Int

    overbookLimit Int?

    waitlistSeats Int?

    fares FlyInventoryFare[]
}

model FlyInventoryFare {
    id String @id @default(cuid())

    cabinInventoryId String
    cabinInventory   FlyCabinInventory @relation(fields: [cabinInventoryId], references: [id], onDelete: Cascade)

    fareId String
    fare   FlyFare @relation(fields: [fareId], references: [id])

    locks     FlyInventoryLock[]
    waitlists FlyWaitlist[]
    available Int

    sold Int

    hold Int

    waitlist Int
}

model FlyInventoryLock {
    id String @id @default(cuid())

    inventoryFareId String
    inventoryFare   FlyInventoryFare @relation(fields: [inventoryFareId], references: [id], onDelete: Cascade)

    bookingId String?
    booking   FlyBooking? @relation(fields: [bookingId], references: [id], onDelete: Cascade)

    userId String?
    user   User?   @relation(fields: [userId], references: [id])

    startTime  DateTime
    releasedAt DateTime?
    status     InventoryLockStatus @default(locked)
    endTime    DateTime
    quantity   Int
    expiresAt  DateTime
    createdAt  DateTime            @default(now())
}

model FlyWaitlist {
    id String @id @default(cuid())

    inventoryFareId String

    inventoryFare FlyInventoryFare @relation(fields: [inventoryFareId], references: [id])

    bookingId String?
    booking   FlyBooking? @relation(fields: [bookingId], references: [id], onDelete: Cascade)

    position Int

    createdAt DateTime @default(now())
}

model FlyOverbookingRule {
    id String @id @default(cuid())

    airlineId String

    airline FlyAirline @relation(fields: [airlineId], references: [id])

    cabinClass FlyCabinClass

    percentage Float
}
