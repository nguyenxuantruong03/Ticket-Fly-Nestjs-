model FlyAlliance {
    id String @id @default(cuid())

    name String

    code String @unique

    logo String?

    description String?

    airlines  FlyAllianceMember[]
    createdAt DateTime            @default(now())

    updatedAt DateTime @updatedAt
}

model FlyAllianceMember {
    id String @id @default(cuid())

    allianceId String
    alliance   FlyAlliance @relation(fields: [allianceId], references: [id], onDelete: Cascade)

    airlineId String
    airline   FlyAirline @relation(fields: [airlineId], references: [id], onDelete: Cascade)

    joinedAt DateTime?

    @@unique([allianceId, airlineId])
}