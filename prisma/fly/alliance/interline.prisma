

model FlyInterline {
    id String @id @default(cuid())

    bookingId String
    booking   FlyBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

    validatingAirlineId String
    validatingAirline   FlyAirline @relation(fields: [validatingAirlineId], references: [id])

    baggageTransfer Boolean

    protectedConnection Boolean
}