
model FlyBaggagePolicy {
    id String @id @default(cuid())

    policiesId String @unique

    policies FlyPolicies @relation(fields: [policiesId], references: [id], onDelete: Cascade)

    cabinIncludedKg Float?

    checkedIncludedKg Float?

    extraAllowed Boolean

    extraPricePerKg Float?
}
