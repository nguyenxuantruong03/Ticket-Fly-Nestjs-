

model FlySeatInventoryLock {
    id String @id @default(cuid())

    tripId String
    trip   FlyTrip @relation(fields: [tripId], references: [id], onDelete: Cascade)

    seatId String
    seat   FlySeat @relation(fields: [seatId], references: [id], onDelete: Cascade)

    userId String?
    user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

    bookingId String?
    booking   FlyBooking? @relation(fields: [bookingId], references: [id], onDelete: Cascade)

    startTime  DateTime
    releasedAt DateTime?
    status     InventoryLockStatus @default(locked)
    endTime    DateTime
    quantity   Int
    expiresAt  DateTime

    createdAt DateTime @default(now())

    @@index([tripId])
    @@index([expiresAt])
}
