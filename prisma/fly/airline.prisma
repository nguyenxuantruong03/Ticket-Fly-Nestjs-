model FlyAirline {
    id String @id @default(cuid())

    name                String
    legalName           String?
    iataCode            String?
    icaoCode            String?
    callsign            String?
    country             String?
    website             String?
    hotline             String?
    email               String?
    logo                String?
    banner              String?
    description         String?
    active              Boolean              @default(true)
    flights             Fly[]
    images              FlyAirlineImage[]
    rating              FlyAirlineRating[]
    alliances           FlyAllianceMember[]
    marketingCodeshares FlyCodeshare[]       @relation("MarketingAirline")
    crew                FlyCrew[]
    operatingCodeshares FlyCodeshare[]       @relation("OperatingAirline")
    meal                FlyMeal[]
    interline           FlyInterline[]
    addon               FlyAddon[]
    wifiPackage         FlyWifiPackage[]
    aircraft            FlyAircraft[]
    overbookingRule     FlyOverbookingRule[]
    insurance           FlyInsurance[]
    createdAt           DateTime             @default(now())
    updatedAt           DateTime             @updatedAt

    @@index([iataCode])
    @@index([icaoCode])
}

model FlyAirlineImage {
    id String @id @default(cuid())

    airlineId String
    airline   FlyAirline @relation(fields: [airlineId], references: [id], onDelete: Cascade)

    url String

    category FlyAirlineImageCategory

    isPrimary Boolean @default(false)

    createdAt DateTime @default(now())
}

model FlyAirlineRating {
    id String @id @default(cuid())

    airlineId String
    airline   FlyAirline @relation(fields: [airlineId], references: [id], onDelete: Cascade)

    userId String
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    overall Float?

    service Float?

    comfort Float?

    food Float?

    entertainment Float?

    punctuality Float?

    createdAt DateTime @default(now())

    updatedAt DateTime @updatedAt
}

model FlyWifiPackage {
    id String @id @default(cuid())

    airlineId String

    airline FlyAirline @relation(fields: [airlineId], references: [id], onDelete: Cascade)

    name String

    dataLimitMb Float?

    durationMinutes Int?

    amount     Float
    passengers FlyPassengerWifi[]
    currency   Currency
}

model FlyAddon {
    id String @id @default(cuid())

    airlineId String?

    airline FlyAirline? @relation(fields: [airlineId], references: [id], onDelete: Cascade)

    name String

    description String?

    type FlyAddonType

    provider String?

    image String?

    amount Float

    currency Currency

    active Boolean @default(true)

    passengerAddons FlyPassengerAddon[]

    createdAt DateTime @default(now())

    updatedAt DateTime @updatedAt

    @@index([type])
}

model FlyPassengerAddon {
    id String @id @default(cuid())

    passengerId String

    passenger FlyPassenger @relation(fields: [passengerId], references: [id], onDelete: Cascade)

    addonId String

    addon FlyAddon @relation(fields: [addonId], references: [id], onDelete: Restrict)

    quantity Int @default(1)

    unitPrice Float

    totalPrice Float

    currency Currency

    metadata Json?

    createdAt DateTime @default(now())

    @@index([passengerId])
    @@index([addonId])
}

model FlySchedule {
    id String @id @default(cuid())

    flyId String

    fly Fly @relation(fields: [flyId], references: [id], onDelete: Cascade)

    departureTime String

    arrivalTime String

    startDate DateTime

    endDate DateTime?

    operatingDays Weekday[]

    aircraftId String?

    aircraft FlyAircraft? @relation(fields: [aircraftId], references: [id])

    active Boolean @default(true)

    trips FlyTrip[]

    createdAt DateTime @default(now())

    updatedAt DateTime @updatedAt
}
