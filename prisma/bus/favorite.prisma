model BusFavorite {
    id String @id @default(cuid())

    userId String
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    busId String
    bus Bus @relation(fields: [busId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now())

    @@unique([userId, busId])
    @@index([userId])
    @@index([busId])
}
