
model BusPriceRule {
    id String @id @default(cuid())

    priceId String
    price   BusPrice @relation(fields: [priceId], references: [id], onDelete: Cascade)

    name String

    type     BusPriceRuleType
    priority Int              @default(0)

    combinable Boolean @default(false)
    percentage Float?

    amount Float?

    minimumSpend Float?

    maximumDiscount Float?

    couponCode String?

    startDate DateTime?

    endDate DateTime?

    active Boolean @default(true)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([priceId])
    @@index([type])
    @@index([active])
}