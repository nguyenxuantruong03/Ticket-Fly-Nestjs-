model BusReview {
    id String @id @default(cuid())

    // ======================================================
    // RELATIONS
    // ======================================================

    busId String
    bus   Bus    @relation(fields: [busId], references: [id], onDelete: Cascade)

    tripId String
    trip   BusTrip @relation(fields: [tripId], references: [id], onDelete: Cascade)

    // Nên dùng nếu hệ thống có booking
    bookingId String?
    booking   BusBooking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

    userId String?
    user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

    // ======================================================
    // RATINGS
    // ======================================================
    anonymous          Boolean @default(false)
    overallRating      Float
    cleanliness        Float?
    comfort            Float?
    busCondition       Float?
    driverService      Float?
    staffService       Float?
    punctuality        Float?
    boardingExperience Float?
    bookingExperience  Float?
    valueForMoney      Float?

    // ======================================================
    // REVIEW CONTENT
    // ======================================================

    title     String?
    comment   String
    pros      String?
    cons      String?
    recommend Boolean?

    // ======================================================
    // REVIEW INFO
    // ======================================================

    verified     Boolean      @default(false)
    status       ReviewStatus @default(pending)
    travelDate   DateTime?
    helpfulCount Int          @default(0)
    response     String?
    responseAt   DateTime?

    // ======================================================
    // MEDIA
    // ======================================================

    images BusReviewImage[]

    // ======================================================
    // TIMESTAMP
    // ======================================================

    createdAt DateTime @default(now())

    updatedAt DateTime @updatedAt

    @@unique([bookingId])
    @@index([busId])
    @@index([userId])
    @@index([overallRating])
    @@index([verified])
    @@index([status])
    @@index([createdAt])
}

model BusReviewImage {
    id        String    @id @default(cuid())
    reviewId  String
    review    BusReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
    url       String
    createdAt DateTime  @default(now())

    @@index([reviewId])
}
