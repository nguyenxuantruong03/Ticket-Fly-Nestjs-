model BusRoute {
    id String @id @default(cuid())

    busId String
    bus   Bus    @relation(fields: [busId], references: [id], onDelete: Cascade)

    departureAddressId String
    departureAddress   Address @relation("BusDepartureAddress", fields: [departureAddressId], references: [id])

    arrivalAddressId String
    arrivalAddress   Address @relation("BusArrivalAddress", fields: [arrivalAddressId], references: [id])

    distanceKm Float?

    estimatedDuration Int?

    boardingPoints BusBoardingPoint[]

    dropoffPoints BusDropoffPoint[]

    trips     BusTrip[]
    code      String?
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt

    @@index([busId])
}

model BusTrip {
    id    String @id @default(cuid())

    routeId          String
    route            BusRoute               @relation(fields: [routeId], references: [id], onDelete: Cascade)
    bookings         BusBooking[]
    seatAvailability BusSeatAvailability[]
    stops            BusRouteStop[]
    locks            BusSeatInventoryLock[]

    departureTime DateTime

    arrivalTime DateTime

    status         BusTripStatus     @default(active)
    boardingStatus BusBoardingStatus
    price          BusTripPrice?
    review         BusReview[]
    createdAt      DateTime          @default(now())

    updatedAt DateTime @updatedAt

    @@index([routeId])
    @@index([departureTime])
}

model BusBoardingPoint {
    id String @id @default(cuid())

    routeId String
    route   BusRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)

    addressId String
    address   Address @relation(fields: [addressId], references: [id], onDelete: Cascade)

    name String?

    departureTime String

    order Int

    createdAt DateTime @default(now())

    @@unique([routeId, order])
}

model BusDropoffPoint {
    id String @id @default(cuid())

    routeId String
    route   BusRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)

    addressId String
    address   Address @relation(fields: [addressId], references: [id], onDelete: Cascade)
    name      String?

    arrivalTime String?

    order Int

    createdAt DateTime @default(now())
}

model BusRouteStop {
    id String @id @default(cuid())

    tripId String

    trip BusTrip @relation(fields: [tripId], references: [id], onDelete: Cascade)

    addressId   String
    address     Address   @relation(fields: [addressId], references: [id], onDelete: Cascade)
    arrivalTime DateTime?

    departureTime DateTime?

    stopOrder Int

    createdAt DateTime @default(now())
}

model BusSeatInventoryLock {
    id String @id @default(cuid())

    bookingId String?
    booking   BusBooking? @relation(fields: [bookingId], references: [id], onDelete: Cascade)

    vehicleId String
    vehicle   BusVehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

    userId String?
    user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

    tripId String
    trip   BusTrip @relation(fields: [tripId], references: [id], onDelete: Cascade)

    startTime  DateTime
    releasedAt DateTime?
    status     InventoryLockStatus @default(locked)
    endTime    DateTime
    quantity   Int
    expiresAt  DateTime

    createdAt DateTime @default(now())

    @@index([expiresAt])
}

model BusSeatAvailability {
    id String @id @default(cuid())

    tripId String
    trip   BusTrip @relation(fields: [tripId], references: [id], onDelete: Cascade)

    seatId String
    seat   BusSeat @relation(fields: [seatId], references: [id], onDelete: Cascade)

    status         BusSeatAvailabilityStatus
    availableSeats Int
    soldSeats      Int
    reservedSeats  Int

    totalSeats   Int
    currentPrice Float
    currency     Currency

    createdAt DateTime @default(now())

    updatedAt DateTime @updatedAt

    @@unique([tripId, seatId])
    @@index([tripId])
    @@index([status])
}
