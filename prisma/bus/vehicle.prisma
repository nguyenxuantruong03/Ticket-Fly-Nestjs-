model BusVehicle {
    id String @id @default(cuid())

    busId String @unique
    bus   Bus    @relation(fields: [busId], references: [id], onDelete: Cascade)

    type   BusVehicleType
    active Boolean        @default(true)
    name   String?

    manufacturer String?

    model String?

    year Int?

    status BusVehicleStatus?

    capacity BusVehicleCapacity?

    features      BusVehicleFeatures?
    seats         BusSeat[]
    locks         BusSeatInventoryLock[]
    specification BusVehicleSpecification?
    seatLayout    BusSeatLayout[]

    images    BusVehicleImage[]
    seatMap   BusSeatMap?
    createdAt DateTime          @default(now())
    updatedAt DateTime          @updatedAt
}

model BusVehicleSpecification {
    id String @id @default(cuid())

    vehicleId String     @unique
    vehicle   BusVehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

    engineType String?

    transmission String?

    fuelType BusFuelType?

    suspension String?

    airConditioning Boolean?

    wifiAvailable Boolean?

    toiletAvailable Boolean?

    createdAt DateTime @default(now())
}

model BusVehicleCapacity {
    id String @id @default(cuid())

    vehicleId String     @unique
    vehicle   BusVehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

    totalSeats Int

    sleeperBeds Int?

    cabinRooms Int?

    luggageCapacityKg Float?

    createdAt DateTime @default(now())
}

model BusVehicleFeatures {
    id String @id @default(cuid())

    vehicleId String     @unique
    vehicle   BusVehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

    airConditioner Boolean?

    wifi Boolean?

    usbCharger Boolean?

    powerOutlet Boolean?

    readingLight Boolean?

    blanket Boolean?

    pillow Boolean?

    drinkingWater Boolean?

    snack Boolean?

    toilet Boolean?

    tv Boolean?

    entertainment Boolean?

    gpsTracking Boolean?

    recliningSeat Boolean?

    massageSeat Boolean?

    wheelchairAccessible Boolean?

    createdAt DateTime @default(now())
}

model BusVehicleImage {
    id String @id @default(cuid())

    vehicleId String
    vehicle   BusVehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

    url String

    category BusVehicleImageCategory

    isPrimary Boolean @default(false)

    sortOrder Int @default(0)

    alt String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model BusSeat {
    id String @id @default(cuid())

    vehicleId String
    vehicle   BusVehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

    seatNumber String

    type BusSeatType

    floor Int?

    row Int?

    column       Int?
    availability BusSeatAvailability[]
    bookingSeat  BusBookingSeat[]
    createdAt    DateTime              @default(now())

    @@unique([vehicleId, seatNumber])
}

model BusSeatLayout {
    id String @id @default(cuid())

    vehicleId String

    vehicle BusVehicle @relation(fields: [vehicleId], references: [id])

    name String

    seatRows Int

    seatColumns Int
}

model BusSeatMap {
    id String @id @default(cuid())

    vehicleId String     @unique
    vehicle   BusVehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

    imageUrl String?

    svgUrl String?

    jsonLayout Json?

    createdAt DateTime @default(now())

    updatedAt DateTime @updatedAt
}
