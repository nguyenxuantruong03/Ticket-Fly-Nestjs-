model BusPolicies {
    id String @id @default(cuid())

    busId String @unique
    bus   Bus    @relation(fields: [busId], references: [id], onDelete: Cascade)

    cancellation BusCancellationPolicy?
    luggage      BusLuggagePolicy?
    child        BusChildPolicy?
    boarding     BusBoardingPolicy?
    change       BusTicketChangePolicy?
    passenger    BusPassengerPolicy?
    createdAt    DateTime               @default(now())
    updatedAt    DateTime               @updatedAt
}

model BusCancellationPolicy {
    id String @id @default(cuid())

    policiesId String      @unique
    policies   BusPolicies @relation(fields: [policiesId], references: [id], onDelete: Cascade)

    refundable                  Boolean       @default(false)
    refundType                  BusRefundType
    freeCancellation            Boolean       @default(false)
    freeCancellationBeforeHours Int?
    cancellationFee             Float?
    noShowFee                   Float?
    createdAt                   DateTime      @default(now())
}

model BusTicketChangePolicy {
    id String @id @default(cuid())

    policiesId String      @unique
    policies   BusPolicies @relation(fields: [policiesId], references: [id], onDelete: Cascade)

    type                       BusTicketChangeType
    changeFee                  Float?
    maxChanges                 Int?
    changeBeforeDepartureHours Int?
    createdAt                  DateTime            @default(now())
}

model BusLuggagePolicy {
    id String @id @default(cuid())

    policiesId String      @unique
    policies   BusPolicies @relation(fields: [policiesId], references: [id], onDelete: Cascade)

    includedLuggage     Float?
    unit                BusLuggageUnit @default(kg)
    extraLuggageAllowed Boolean        @default(false)
    extraLuggageFee     Float?
    createdAt           DateTime       @default(now())
}

model BusChildPolicy {
    id String @id @default(cuid())

    policiesId String      @unique
    policies   BusPolicies @relation(fields: [policiesId], references: [id], onDelete: Cascade)

    freeAgeUnder         Int?
    childTicketAgeFrom   Int?
    childTicketAgeTo     Int?
    childDiscountPercent Float?
    createdAt            DateTime @default(now())
}

model BusBoardingPolicy {
    id String @id @default(cuid())

    policiesId String      @unique
    policies   BusPolicies @relation(fields: [policiesId], references: [id], onDelete: Cascade)

    checkInBeforeMinutes     Int?
    boardingGateCloseMinutes Int?
    digitalTicketAccepted    Boolean  @default(true)
    printedTicketRequired    Boolean  @default(false)
    createdAt                DateTime @default(now())
}

model BusPassengerPolicy {
    id String @id @default(cuid())

    policiesId String      @unique
    policies   BusPolicies @relation(fields: [policiesId], references: [id], onDelete: Cascade)

    petsAllowed                Boolean  @default(false)
    smokingAllowed             Boolean  @default(false)
    foodAllowed                Boolean  @default(true)
    alcoholAllowed             Boolean  @default(false)
    wheelchairAccessible       Boolean  @default(false)
    specialAssistanceAvailable Boolean  @default(false)
    createdAt                  DateTime @default(now())
}