model BusTrip {
    id String @id @default(cuid())

    vehicleId String
    vehicle   BusVehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

    routeId          String
    route            BusRoute               @relation(fields: [routeId], references: [id], onDelete: Cascade)
    bookings         BusBooking[]
    seatAvailability BusSeatAvailability[]
    stops            BusRouteStop[]
    locks            BusSeatInventoryLock[]

    departureTime DateTime

    arrivalTime DateTime

    status         BusTripStatus     @default(active)
    boardingStatus BusBoardingStatus
    price          BusTripPrice?
    review         BusReview[]
    createdAt      DateTime          @default(now())

    updatedAt DateTime @updatedAt

    @@index([routeId])
    @@index([departureTime])
}
