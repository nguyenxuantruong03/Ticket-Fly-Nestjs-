


model BusSeatAvailability {
    id String @id @default(cuid())

    tripId String
    trip   BusTrip @relation(fields: [tripId], references: [id], onDelete: Cascade)

    seatId String
    seat   BusSeat @relation(fields: [seatId], references: [id], onDelete: Cascade)

    status         BusSeatAvailabilityStatus
    availableSeats Int
    soldSeats      Int
    reservedSeats  Int

    totalSeats   Int
    currentPrice Float
    currency     Currency

    createdAt DateTime @default(now())

    updatedAt DateTime @updatedAt

    @@unique([tripId, seatId])
    @@index([tripId])
    @@index([status])
}
