model BusTicket {
    id        String     @id @default(cuid())
    bookingId String
    booking   BusBooking @relation(fields: [bookingId], references: [id])

    ticketNumber String    @unique
    issuedAt     DateTime?

    status BusTicketStatus

    seatNumber   String?
    qrCode       String?
    boardingPass BusBoardingPass?
    barcode      String?
}

model BusBoardingPass {
    id String @id @default(cuid())

    ticketId String    @unique
    ticket   BusTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

    status BoardingPassStatus @default(issued)

    boardingTime DateTime?
    scannedAt    DateTime?
    gate         String?
    platform     String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}
