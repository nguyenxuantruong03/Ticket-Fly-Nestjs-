model BusBooking {
    id String @id @default(cuid())

    busId String
    bus   Bus    @relation(fields: [busId], references: [id])

    tripId String
    trip   BusTrip @relation(fields: [tripId], references: [id])

    userId String
    user   User   @relation(fields: [userId], references: [id])

    ticket         BusTicket[]
    note           String?
    specialRequest String?
    status         BusBookingStatus
    statusHistory  BusBookingStatusHistory[]
    passengers     BusBookingPassenger[]
    reviews        BusReview[]
    seats          BusBookingSeat[]
    expiresAt      DateTime?
    priceSnapshot  BusBookingPriceSnapshot?
    locks          BusSeatInventoryLock[]
    paymentStatus  BusPaymentStatus          @default(unpaid)
    createdAt      DateTime                  @default(now())
    updatedAt      DateTime                  @updatedAt

    @@index([status])
    @@index([createdAt])
    @@index([tripId])
    @@index([userId])
}