model BusBooking {
    id String @id @default(cuid())

    busId String
    bus   Bus    @relation(fields: [busId], references: [id])

    tripId String
    trip   BusTrip @relation(fields: [tripId], references: [id])

    userId String
    user   User   @relation(fields: [userId], references: [id])

    ticket         BusTicket[]
    note           String?
    specialRequest String?
    status         BusBookingStatus
    statusHistory  BusBookingStatusHistory[]
    passengers     BusBookingPassenger[]
    reviews        BusReview[]
    seats          BusBookingSeat[]
    expiresAt      DateTime?
    priceSnapshot  BusBookingPriceSnapshot?
    locks          BusSeatInventoryLock[]
    paymentStatus  BusPaymentStatus          @default(unpaid)
    createdAt      DateTime                  @default(now())
    updatedAt      DateTime                  @updatedAt

    @@index([status])
    @@index([createdAt])
    @@index([tripId])
    @@index([userId])
}

model BusBookingStatusHistory {
    id String @id @default(cuid())

    bookingId String
    booking   BusBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

    status BusBookingStatus

    note String?

    createdAt DateTime @default(now())

    @@index([bookingId])
}

model BusBookingPassenger {
    id String @id @default(cuid())

    bookingId String

    booking     BusBooking @relation(fields: [bookingId], references: [id])
    nationality String?

    firstName      String
    lastName       String
    phone          String
    email          String
    documentType   PassengerDocumentType
    documentNumber String

    dateOfBirth DateTime?

    gender Gender?
}

model BusBookingSeat {
    id String @id @default(cuid())

    bookingId String

    booking BusBooking @relation(fields: [bookingId], references: [id])

    seatId String

    seat BusSeat @relation(fields: [seatId], references: [id])

    price Float

    @@unique([bookingId, seatId])
}

model BusBookingPriceSnapshot {
    id String @id @default(cuid())

    bookingId String @unique

    booking BusBooking @relation(fields: [bookingId], references: [id])

    subtotal Float

    taxes Float

    serviceFee Float

    discount Float

    total Float

    currency Currency
}
