model BusPrice {
    id String @id @default(cuid())

    busId String @unique
    bus   Bus    @relation(fields: [busId], references: [id], onDelete: Cascade)

    currency  Currency
    // Giá hiển thị ngoài danh sách
    fromPrice Float

    // Giá cao nhất (nếu muốn hiển thị khoảng giá)
    toPrice Float?

    // Giá trước giảm
    originalFromPrice Float?
    originalToPrice   Float?
    breakdowns        BusPriceBreakdown[]
    rules             BusPriceRule[]

    effectiveFrom DateTime?
    effectiveTo   DateTime?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([fromPrice])
}

model BusPriceBreakdown {
    id String @id @default(cuid())

    priceId String
    price   BusPrice @relation(fields: [priceId], references: [id], onDelete: Cascade)

    seatType BusSeatType

    basePrice Float

    originalPrice Float?

    taxes Float @default(0)

    serviceFee Float @default(0)

    bookingFee Float @default(0)

    discount Float @default(0)

    finalPrice Float

    availableSeats Int?

    includedItems String[] @default([])

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([priceId])
    @@index([seatType])
}

model BusPriceRule {
    id String @id @default(cuid())

    priceId String
    price   BusPrice @relation(fields: [priceId], references: [id], onDelete: Cascade)

    name String

    type     BusPriceRuleType
    priority Int              @default(0)

    combinable Boolean @default(false)
    percentage Float?

    amount Float?

    minimumSpend Float?

    maximumDiscount Float?

    couponCode String?

    startDate DateTime?

    endDate DateTime?

    active Boolean @default(true)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([priceId])
    @@index([type])
    @@index([active])
}

model BusTripPrice {
    id String @id @default(cuid())

    tripId String @unique

    trip BusTrip @relation(fields: [tripId], references: [id], onDelete: Cascade)

    seatPrices BusSeatPrice[]

    createdAt DateTime @default(now())

    updatedAt DateTime @updatedAt
}

model BusSeatPrice {
    id String @id @default(cuid())

    tripPriceId String

    tripPrice BusTripPrice @relation(fields: [tripPriceId], references: [id], onDelete: Cascade)

    seatType BusSeatType

    price Float

    originalPrice Float?

    taxes Float @default(0)

    serviceFee Float @default(0)

    bookingFee Float @default(0)

    discount Float @default(0)

    finalPrice Float

    availableSeats Int?

    createdAt DateTime @default(now())

    @@index([tripPriceId])
    @@index([seatType])
}

