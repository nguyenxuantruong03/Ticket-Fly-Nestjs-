model YachtVehicleFacilities {
    id String @id @default(cuid())

    vehicleId String       @unique
    vehicle   YachtVehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

    wifi Boolean?

    bluetooth Boolean?

    tv Boolean?

    soundSystem Boolean?

    kitchen Boolean?

    refrigerator Boolean?

    coffeeMachine Boolean?

    bar Boolean?

    jacuzzi Boolean?

    swimmingPlatform Boolean?

    sunDeck Boolean?

    airConditioning Boolean?

    heating Boolean?

    shower Boolean?

    toilet Boolean?

    fishingEquipment Boolean?

    snorkelingEquipment Boolean?

    divingEquipment Boolean?
}

model YachtSafetyEquipment {
    id String @id @default(cuid())

    vehicleId String @unique

    vehicle YachtVehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

    lifeJacket Boolean?

    lifeRaft Boolean?

    fireExtinguisher Boolean?

    fireAlarm Boolean?

    firstAidKit Boolean?

    gps Boolean?

    radar Boolean?

    emergencyRadio Boolean?

    insurance Boolean?
}

model YachtMarinaFacilities {
    id String @id @default(cuid())

    marinaId String      @unique
    marina   YachtMarina @relation(fields: [marinaId], references: [id], onDelete: Cascade)

    fuelStation Boolean?

    restaurant Boolean?

    cafe Boolean?

    parking Boolean?

    waitingLounge Boolean?

    toilet Boolean?

    shower Boolean?

    drinkingWater Boolean?

    electricity Boolean?

    wifi Boolean?

    security Boolean?

    cctv Boolean?

    luggageStorage Boolean?

    convenienceStore Boolean?

    atm Boolean?

    customs Boolean?

    immigration Boolean?
}
