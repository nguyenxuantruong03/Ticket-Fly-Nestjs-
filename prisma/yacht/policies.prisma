model YachtPolicies {
    id String @id @default(cuid())

    yachtId String @unique

    yacht Yacht @relation(fields: [yachtId], references: [id], onDelete: Cascade)

    cancellation YachtCancellationPolicy?

    passenger YachtPassengerRequirement?

    luggage YachtLuggagePolicy?

    waiting YachtWaitingPolicy?

    meetAndGreet YachtMeetAndGreet?

    flightSupport YachtFlightSupport?

    booking YachtBookingPolicy?

    createdAt DateTime @default(now())

    updatedAt DateTime @updatedAt
}

model YachtCancellationPolicy {
    id String @id @default(cuid())

    policiesId String @unique

    policies YachtPolicies @relation(fields: [policiesId], references: [id], onDelete: Cascade)

    refundable Boolean @default(false)

    freeCancellation Boolean @default(false)

    freeCancellationBeforeHours Int?

    cancellationType YachtRefundType

    refundPercentage Float?

    cancellationFee Float?

    noShowFee Float?
}

model YachtPassengerRequirement {
    id String @id @default(cuid())

    policiesId String @unique

    policies YachtPolicies @relation(fields: [policiesId], references: [id], onDelete: Cascade)

    minimumAge Int?

    passportRequired Boolean @default(false)

    identityRequired Boolean @default(false)

    nationalityRestriction String[]

    childAllowed Boolean @default(true)

    infantAllowed Boolean @default(true)

    pregnantPassengerAllowed Boolean?
}

model YachtLuggagePolicy {
    id String @id @default(cuid())

    policiesId String @unique

    policies YachtPolicies @relation(fields: [policiesId], references: [id], onDelete: Cascade)

    allowed Boolean @default(true)

    maxWeightKg Float?

    maxPieces Int?

    oversizedAllowed Boolean?

    note String?
}

model YachtWaitingPolicy {
    id String @id @default(cuid())

    policiesId String @unique

    policies YachtPolicies @relation(fields: [policiesId], references: [id], onDelete: Cascade)

    freeWaitingMinutes Int?

    extraWaitingFeePerHour Float?

    maximumWaitingHours Int?
}

model YachtMeetAndGreet {
    id String @id @default(cuid())

    policiesId String @unique

    policies YachtPolicies @relation(fields: [policiesId], references: [id], onDelete: Cascade)

    available Boolean @default(false)

    pickupSign Boolean?

    staffLanguage String[]

    meetingPoint String?
}

model YachtFlightSupport {
    id String @id @default(cuid())

    policiesId String @unique

    policies YachtPolicies @relation(fields: [policiesId], references: [id], onDelete: Cascade)

    airportPickup Boolean?

    flightNumberRequired Boolean?

    flightDelayMonitoring Boolean?
}

model YachtBookingPolicy {
    id String @id @default(cuid())

    policiesId String @unique

    policies YachtPolicies @relation(fields: [policiesId], references: [id], onDelete: Cascade)

    instantConfirmation Boolean @default(true)

    advanceBookingHours Int?

    minimumBookingDuration Int?

    modificationAllowed Boolean?
}
