model YachtBooking {
    id String @id @default(cuid())

    // ==========================
    // USER
    // ==========================

    userId String
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    // ==========================
    // PRODUCT
    // ==========================

    yachtId String
    yacht   Yacht  @relation(fields: [yachtId], references: [id])

    tripId String?
    trip   YachtTrip? @relation(fields: [tripId], references: [id])

    packageId String?
    package   YachtPackage? @relation(fields: [packageId], references: [id])

    // ==========================
    // BOOKING INFO
    // ==========================

    bookingCode String @unique

    bookingDate DateTime @default(now())

    startTime DateTime

    endTime DateTime?

    guestCount Int

    status  YachtBookingStatus @default(pending)
    reviews YachtReview[]
    // ==========================
    // PRICE
    // ==========================

    currency Currency

    subtotal Float

    tax Float @default(0)

    discount Float @default(0)

    serviceFee Float @default(0)

    total Float

    // ==========================
    // RELATION
    // ==========================

    passengers YachtBookingPassenger[]

    extras        YachtBookingExtra[]
    contact       YachtBookingContact?
    pickup        YachtBookingPickup?
    statusHistory YachtBookingStatusHistory[]
    locks         YachtInventoryLock[]

    createdAt DateTime @default(now())

    updatedAt DateTime @updatedAt

    @@index([userId])
    @@index([yachtId])
    @@index([status])
}

model YachtBookingPassenger {
    id String @id @default(cuid())

    bookingId String
    booking   YachtBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

    fullName String

    nationality String?

    passportNumber String?

    dateOfBirth DateTime?
    gender      Gender

    email String

    phone          String
    expiresAt      String
    identityNumber String
    type           YachtPassengerType
}

model YachtBookingExtra {
    id String @id @default(cuid())

    bookingId String
    booking   YachtBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

    extraId String?
    extra   YachtExtra? @relation(fields: [extraId], references: [id])

    quantity Int @default(1)

    price Float

    total Float
}

enum VoucherDiscountType {
    percentage

    fixed
}

model YachtBookingContact {
    id String @id @default(cuid())

    bookingId String @unique

    booking YachtBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

    fullName String

    email String?

    phone String

    note String?
}

model YachtBookingPickup {
    id String @id @default(cuid())

    bookingId String @unique

    booking YachtBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

    pickupRequired Boolean @default(false)

    addressId String?
    address   Address? @relation(fields: [addressId], references: [id])

    pickupTime DateTime?

    note String?
}

model YachtBookingStatusHistory {
    id String @id @default(cuid())

    bookingId String

    booking YachtBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

    fromStatus YachtBookingStatus?

    toStatus YachtBookingStatus

    note String?

    createdAt DateTime @default(now())

    @@index([bookingId])
}
