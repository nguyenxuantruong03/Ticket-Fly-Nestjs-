model YachtRouteStop {
    id String @id @default(cuid())

    routeId String
    route   YachtRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)

    name      String
    addressId String

    address Address @relation(fields: [addressId], references: [id], onDelete: Restrict)

    stopDurationMinutes Int?

    order Int

    @@unique([routeId, order])
}
