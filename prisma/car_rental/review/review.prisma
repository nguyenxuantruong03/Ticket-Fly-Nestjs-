model CarRentalReview {
    id String @id @default(cuid())

    rentalId String
    rental   CarRental @relation(fields: [rentalId], references: [id], onDelete: Cascade)

    bookingId String?
    booking   CarRentalBooking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

    userId String?
    user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

    overallRating    Float
    cleanliness      Float?
    vehicleCondition Float?
    service          Float?
    pickupExperience Float?
    valueForMoney    Float?
    title            String?
    comment          String
    pros             String?
    cons             String?
    verified         Boolean      @default(false)
    status           ReviewStatus @default(pending)
    anonymous        Boolean      @default(false)
    rentalDate       DateTime?
    helpfulCount     Int          @default(0)
    response         String?
    responseAt       DateTime?

    images CarRentalReviewImage[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([bookingId])
    @@index([rentalId])
    @@index([overallRating])
    @@index([verified])
    @@index([status])
    @@index([createdAt])
}