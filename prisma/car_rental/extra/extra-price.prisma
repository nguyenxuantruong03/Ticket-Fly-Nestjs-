

model CarRentalExtraPrice {
    id String @id @default(cuid())

    extraId String

    extra CarRentalExtra @relation(fields: [extraId], references: [id], onDelete: Cascade)

    pricingType CarRentalExtraPricingType

    amount Float


    minimumQuantity Int?

    maximumQuantity Int?

    startDate DateTime?

    endDate DateTime?

    createdAt DateTime @default(now())

    @@index([extraId])
}

