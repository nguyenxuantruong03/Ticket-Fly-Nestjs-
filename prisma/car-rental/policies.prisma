// ======================================================
// ENUMS
// ======================================================

enum UnitOption {
    km
    m
}

enum FuelPolicy {
    full_to_full
    same_level
    prepaid
    electric_charge
}

enum RentalDocument {
    passport
    driver_license
    international_driver_license
    identity_card
    credit_card
}

model CarRentalPolicies {
    id String @id @default(cuid())

    rentalId            String                       @unique
    rental              CarRental                    @relation(fields: [rentalId], references: [id])
    minimumDriverAge    Int?
    minimumLicenseYears Int?
    depositAmount       Float?
    mileage             CarRentalMileagePolicy?
    cancellation        CarRentalCancellationPolicy?
    rules               CarRentalRules?
    requiredDocuments   CarRentalRequiredDocuments?
    fuelPolicy          FuelPolicy?

    damagePolicy CarRentalDamagePolicy?
}

model CarRentalDamagePolicy {
    id String @id @default(cuid())

    policiesId String            @unique
    policies   CarRentalPolicies @relation(fields: [policiesId], references: [id])

    insuranceIncluded Boolean?
    excessAmount      Float?
    depositRequired   Boolean?
}

model CarRentalMileagePolicy {
    id String @id @default(cuid())

    unlimited Boolean

    unit UnitOption

    dailyLimitKm Float?

    extraKmFee Float?

    policiesId String            @unique
    policies   CarRentalPolicies @relation(fields: [policiesId], references: [id])
}

model CarRentalCancellationPolicy {
    id String @id @default(cuid())

    refundable Boolean

    freeCancellation Boolean

    freeCancellationBeforeHours Float?

    partialRefund Boolean?

    cancellationFee Float?

    noShowFee Float

    policiesId String            @unique
    policies   CarRentalPolicies @relation(fields: [policiesId], references: [id])
}

model CarRentalRules {
    id String @id @default(cuid())

    minimumAge Int?

    maximumAge Int?

    requiresDriverLicense Boolean?

    requiresInternationalLicense Boolean?

    minimumDrivingExperienceYears Int?

    smokingAllowed Boolean?

    petsAllowed Boolean?

    offRoadAllowed Boolean?

    crossBorderAllowed Boolean?

    additionalDriverAllowed Boolean?

    lateReturnFeePerHour Float?

    policiesId String            @unique
    policies   CarRentalPolicies @relation(fields: [policiesId], references: [id])
}

model CarRentalRequiredDocuments {
    id String @id @default(cuid())

    documents RentalDocument[]

    policiesId String            @unique
    policies   CarRentalPolicies @relation(fields: [policiesId], references: [id])
}
