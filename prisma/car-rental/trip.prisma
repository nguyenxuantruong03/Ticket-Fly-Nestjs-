model CarRentalTrip {
    id String @id @default(cuid())

    rentalId  String              @unique
    rental    CarRental           @relation(fields: [rentalId], references: [id], onDelete: Cascade)
    locations CarRentalLocation[]
    schedule  CarRentalSchedule?
    tripFee   CarRentalTripFee?
}

model CarRentalTripFee {
    id String @id @default(cuid())

    tripId      String        @unique
    trip        CarRentalTrip @relation(fields: [tripId], references: [id], onDelete: Cascade)
    airportFee  Float?
    oneWayFee   Float?
    deliveryFee Float?
    pickupFee   Float?
    dropoffFee  Float?
}

model CarRentalLocation {
    id String @id @default(cuid())

    tripId String
    trip   CarRentalTrip @relation(fields: [tripId], references: [id], onDelete: Cascade)

    bookingId String?
    booking   CarRentalBooking? @relation(fields: [bookingId], references: [id], onDelete: Cascade)

    type RentalLocationType

    name String

    addressId String
    address   Address @relation(fields: [addressId], references: [id], onDelete: Restrict)

    available Boolean  @default(true)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([bookingId, type])
    @@index([tripId])
    @@index([type])
    @@index([addressId])
}

model CarRentalSchedule {
    id String @id @default(cuid())

    tripId String        @unique
    trip   CarRentalTrip @relation(fields: [tripId], references: [id], onDelete: Cascade)

    durationType RentalDurationType
    minimumHours Int?
    minimumDays  Int?
    maximumDays  Int?
    pickupTime   String?
    returnTime   String?
}

model CarRentalInventoryLock {
    id String @id @default(cuid())

    bookingId String?
    booking   CarRentalBooking? @relation(fields: [bookingId], references: [id], onDelete: Cascade)

    vehicleId String
    vehicle   CarRentalVehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

    userId String?
    user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

    startTime  DateTime
    releasedAt DateTime?
    status     InventoryLockStatus @default(locked)
    endTime    DateTime
    quantity   Int
    expiresAt  DateTime

    createdAt DateTime @default(now())

    @@index([expiresAt])
}

model CarRentalDriver {
    id String @id @default(cuid())

    rentalId String
    rental   CarRental @relation(fields: [rentalId], references: [id], onDelete: Cascade)

    name  String
    phone String?

    languages String[]

    experienceYears Int?

    rating Float @default(0)

    status DriverStatus @default(active)

    image String?

    createdAt DateTime @default(now())

    updatedAt DateTime @updatedAt

    @@index([rentalId])
}

model CarRentalPickupInstruction {
    id String @id @default(cuid())

    rentalId String
    rental   CarRental @relation(fields: [rentalId], references: [id], onDelete: Cascade)

    type PickupInstructionType

    title String

    description String?

    location String?

    contactPhone String?

    createdAt DateTime @default(now())

    @@index([rentalId])
}
