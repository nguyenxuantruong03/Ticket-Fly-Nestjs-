model HotelBooking {
    id String @id @default(cuid())

    hotelId String
    hotel   Hotel  @relation(fields: [hotelId], references: [id])

    userId String?
    user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

    status         HotelBookingStatus          @default(pending)
    checkIn        DateTime
    checkOut       DateTime
    totalRooms     Int
    rooms          HotelBookingRoom[]
    guests         HotelBookingGuest[]
    price          HotelBookingPriceSnapshot?
    statusHistory  HotelBookingStatusHistory[]
    specialRequest String?

    extras    HotelBookingExtra[]
    meals     HotelBookingMeal[]
    expiresAt DateTime?
    locks     HotelInventoryLock[]
    reviews   HotelReview[]
    createdAt DateTime             @default(now())
    updatedAt DateTime             @updatedAt

    @@index([hotelId])
    @@index([userId])
    @@index([status])
}

model HotelBookingRoom {
    id String @id @default(cuid())

    bookingId String
    booking   HotelBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

    inventoryId String?
    inventory   HotelInventory? @relation(fields: [inventoryId], references: [id], onDelete: SetNull)

    roomName String

    roomTypeId String?
    roomType   HotelRoomType? @relation(fields: [roomTypeId], references: [id], onDelete: SetNull)

    quantity Int @default(1)

    adults Int @default(1)

    children Int @default(0)

    price HotelBookingRoomPrice?

    createdAt DateTime @default(now())

    @@index([bookingId])
}

model HotelBookingRoomPrice {
    id String @id @default(cuid())

    bookingRoomId String @unique

    bookingRoom   HotelBookingRoom @relation(fields: [bookingRoomId], references: [id], onDelete: Cascade)
    originalPrice Float
    nightlyPrice  Float

    nights Int

    subtotal Float

    tax Float @default(0)

    serviceFee Float @default(0)

    discount Float @default(0)

    total Float

    currency Currency
}

model HotelBookingPriceSnapshot {
    id String @id @default(cuid())

    bookingId String       @unique
    booking   HotelBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

    roomAmount   Float
    currencyRate Float
    taxAmount    Float @default(0)

    serviceFee Float @default(0)

    discount Float @default(0)

    totalAmount   Float
    depositAmount Float    @default(0)
    payableNow    Float
    payableLater  Float
    currency      Currency

    createdAt DateTime @default(now())
}

model HotelBookingGuest {
    id String @id @default(cuid())

    bookingId String

    booking HotelBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

    firstName String

    lastName String

    email String?

    phone String?

    nationality String?

    passportNumber  String?
    passportCountry String?
    dateOfBirth     String?
    gender          Gender
    isMainGuest     Boolean @default(false)

    createdAt DateTime @default(now())

    @@index([bookingId])
}

model HotelBookingStatusHistory {
    id String @id @default(cuid())

    bookingId String
    booking   HotelBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

    status HotelBookingStatus

    note String?

    createdAt DateTime @default(now())

    @@index([bookingId])
}

model HotelExtra {
    id String @id @default(cuid())

    hotelId String
    hotel   Hotel  @relation(fields: [hotelId], references: [id], onDelete: Cascade)

    name String

    description String?

    type HotelExtraType

    required Boolean @default(false)

    prices HotelExtraPrice[]

    bookingExtras HotelBookingExtra[]

    active Boolean @default(true)

    createdAt DateTime @default(now())

    updatedAt DateTime @updatedAt

    @@index([hotelId])
}

model HotelExtraPrice {
    id String @id @default(cuid())

    extraId String

    extra HotelExtra @relation(fields: [extraId], references: [id], onDelete: Cascade)

    price Float

    currency Currency

    unit ExtraPriceUnit

    active Boolean @default(true)

    createdAt DateTime @default(now())

    @@index([extraId])
}

model HotelBookingExtra {
    id String @id @default(cuid())

    bookingId String

    booking HotelBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

    extraId String?

    extra HotelExtra? @relation(fields: [extraId], references: [id], onDelete: SetNull)

    name String

    quantity Int @default(1)

    price Float

    total Float

    currency Currency

    createdAt DateTime @default(now())

    @@index([bookingId])
}

model HotelMealOption {
    id String @id @default(cuid())

    hotelId String

    hotel        Hotel              @relation(fields: [hotelId], references: [id], onDelete: Cascade)
    bookingMeals HotelBookingMeal[]
    name         String

    description String?

    type HotelMealType

    prices HotelMealPrice[]

    active Boolean @default(true)

    createdAt DateTime @default(now())

    @@index([hotelId])
}

model HotelMealPrice {
    id String @id @default(cuid())

    mealId String

    meal HotelMealOption @relation(fields: [mealId], references: [id], onDelete: Cascade)

    price Float

    currency Currency

    unit MealPriceUnit

    createdAt DateTime @default(now())

    @@index([mealId])
}

model HotelBookingMeal {
    id String @id @default(cuid())

    bookingId String

    booking HotelBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

    mealId String?
    meal   HotelMealOption? @relation(fields: [mealId], references: [id], onDelete: SetNull)

    name String

    quantity Int @default(1)

    price Float

    total Float

    currency Currency

    createdAt DateTime @default(now())

    @@index([bookingId])
}
