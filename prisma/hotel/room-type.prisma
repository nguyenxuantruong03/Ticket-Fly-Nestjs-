model HotelRoomType {
    id String @id @default(cuid())

    hotelId String
    hotel   Hotel  @relation(fields: [hotelId], references: [id], onDelete: Cascade)

    name         String
    description  String?
    // ví dụ
    // Deluxe
    // Suite
    // Villa
    inventories  HotelInventory[]
    bookingRooms HotelBookingRoom[]
    rooms        HotelRoom[]
    reviews      HotelReview[]
    active       Boolean            @default(false)
    sortOrder    Int                @default(0)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([hotelId])
}

model HotelRoom {
    id String @id @default(cuid())

    roomTypeId String
    roomType   HotelRoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)

    roomFacilities HotelRoomFacilities?
    active         Boolean              @default(false)

    name        String
    description String?
    roomSize    Float?
    bedTypes    BedType[]

    maxGuests   Int?
    maxAdults   Int?
    maxChildren Int?

    totalRooms        Int?
    breakfastIncluded Boolean?

    smokingPolicy   SmokingPolicy?
    mealPlan        MealPlan?
    bedCount        Int?
    bathroomCount   Float?
    viewType        RoomViewType?
    bathRoomType    BathroomType?
    roomImage       HotelRoomImage[]
    floor           Int?
    soundproof      Boolean?
    nonSmoking      Boolean?
    airConditioning Boolean?
    kitchenette     Boolean?
    privateBathroom Boolean?
}

model HotelRoomImage {
    id String @id @default(cuid())

    roomId String
    room   HotelRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

    thumbnail  String?
    cover      String?
    hero       String?
    rooms      String[]
    bedroom    String[]
    bathroom   String[]
    balcony    String[]
    livingRoom String[]
    kitchen    String[]
    workspace  String[]
    view       String[]

    gallery String[]
}
