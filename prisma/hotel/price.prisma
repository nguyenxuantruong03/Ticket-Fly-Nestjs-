model HotelRoomPrice {
    id String @id @default(cuid())

    ratePlanId String        @unique
    ratePlan   HotelRatePlan @relation(fields: [ratePlanId], references: [id], onDelete: Cascade)

    currency            Currency
    originalPrice       Float?
    averageNightlyPrice Float?
    taxesIncluded       Boolean                  @default(false)
    payAtHotel          Boolean                  @default(false)
    breakdown           HotelRoomPriceBreakdown?
    rules               HotelRoomPriceRule[]
}

model HotelRoomPriceRule {
    id String @id @default(cuid())

    priceId String
    price   HotelRoomPrice @relation(fields: [priceId], references: [id], onDelete: Cascade)

    name String?

    type           HotelPriceRuleType
    adjustmentType HotelPriceAdjustmentType
    value          Float
    currency       Currency?
    minimumNights  Int?
    maximumNights  Int?
    validFrom      DateTime?
    validTo        DateTime?
    daysOfWeek     Weekday[]
    priority       Int                      @default(0)
    combinable     Boolean                  @default(false)
    active         Boolean                  @default(true)
    createdAt      DateTime                 @default(now())
    updatedAt      DateTime                 @updatedAt

    @@index([type])
    @@index([active])
    @@index([validFrom, validTo])
    @@index([priceId, active])
}

model HotelRoomPriceBreakdown {
    id      String         @id @default(cuid())
    priceId String         @unique
    price   HotelRoomPrice @relation(fields: [priceId], references: [id], onDelete: Cascade)

    roomRate      Float    @default(0)
    nights        Int      @default(1)
    taxes         Float    @default(0)
    serviceFee    Float    @default(0)
    resortFee     Float    @default(0)
    cleaningFee   Float    @default(0)
    extraFee      Float    @default(0)
    discount      Float    @default(0)
    includedItems String[] @default([])
}
