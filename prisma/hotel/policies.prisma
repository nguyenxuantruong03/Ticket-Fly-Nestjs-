model HotelPolicies {
    id String @id @default(cuid())

    ratePlanId String        @unique
    ratePlan   HotelRatePlan @relation(fields: [ratePlanId], references: [id], onDelete: Cascade)

    checkIn      HotelCheckInPolicy?
    guest        HotelGuestPolicy?
    payment      HotelPaymentPolicy?
    cancellation HotelCancellationPolicy?
    booking      HotelBookingPolicy?
    houseRules   HotelHouseRules?

    @@index([ratePlanId])
}

model HotelHouseRules {
    quietHoursStart String?
    quietHoursEnd   String?
    partiesAllowed  Boolean?
    visitorsAllowed Boolean?
    alcoholAllowed  Boolean?
    policiesId      String        @unique
    policies        HotelPolicies @relation(fields: [policiesId], references: [id], onDelete: Cascade)
}

model HotelCheckInPolicy {
    id String @id @default(cuid())

    checkInTime  String
    checkOutTime String

    frontDesk24Hours Boolean?
    selfCheckIn      Boolean?
    expressCheckIn   Boolean?
    expressCheckOut  Boolean?

    keyCollectionNote String?

    policiesId String        @unique
    policies   HotelPolicies @relation(fields: [policiesId], references: [id], onDelete: Cascade)
}

model HotelGuestPolicy {
    id String @id @default(cuid())

    minimumAge Int?

    childrenAllowed Boolean?
    petsAllowed     Boolean?
    smokingAllowed  Boolean?

    extraBedAvailable Boolean?
    extraBedFee       Float?

    policiesId String        @unique
    policies   HotelPolicies @relation(fields: [policiesId], references: [id], onDelete: Cascade)
}

model HotelPaymentPolicy {
    id String @id @default(cuid())

    paymentTypes  String[]
    acceptedCards String[]

    cashAccepted    Boolean?
    depositRequired Boolean?
    depositAmount   Float?

    policiesId String        @unique
    policies   HotelPolicies @relation(fields: [policiesId], references: [id], onDelete: Cascade)
}

model HotelCancellationPolicy {
    id String @id @default(cuid())

    freeCancellation            Boolean?
    freeCancellationBeforeHours Int?

    cancellationFee Float?
    noShowFee       Float?

    policiesId String        @unique
    policies   HotelPolicies @relation(fields: [policiesId], references: [id], onDelete: Cascade)
}

model HotelBookingPolicy {
    id String @id @default(cuid())

    policiesId          String        @unique
    policies            HotelPolicies @relation(fields: [policiesId], references: [id], onDelete: Cascade)
    instantConfirmation Boolean
    refundable          Boolean
    payAtHotel          Boolean?
    payLater            Boolean?
    breakfastIncluded Boolean?
    mobileVoucher Boolean?
    onlineCheckIn  Boolean?
    onlineCheckOut Boolean?
    requiresCreditCardGuarantee Boolean?
    requiresDeposit             Boolean?
    requiresGovernmentId        Boolean?
    allowsModification Boolean?
}
