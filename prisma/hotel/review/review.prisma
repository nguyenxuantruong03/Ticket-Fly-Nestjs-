model HotelReview {
    id String @id @default(cuid())

    hotelId String
    hotel   Hotel  @relation(fields: [hotelId], references: [id], onDelete: Cascade)

    bookingId String?
    booking   HotelBooking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

    userId String
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    tripType TripType?

    wouldRecommend Boolean?
    language       String?
    anonymous      Boolean            @default(false)
    overallRating  Float
    status         ReviewStatus       @default(pending)
    response       String?
    responseAt     DateTime?
    helpfulCount   Int                @default(0)
    images         HotelReviewImage[]
    cleanliness    Float?
    service        Float?
    location       Float?
    facilities     Float?
    valueForMoney  Float?
    comfort        Float?
    sleepQuality   Float?
    food           Float?
    wifi           Float?

    title           String?
    comment         String
    pros            String?
    cons            String?
    verified        Boolean   @default(false)
    reviewerName    String?
    reviewerCountry String?
    stayDate        DateTime?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([bookingId])
    @@index([hotelId])
    @@index([overallRating])
    @@index([verified])
    @@index([createdAt])
}