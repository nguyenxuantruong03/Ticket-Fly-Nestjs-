

model HotelInventoryLock {
    id String @id @default(cuid())

    inventoryId String
    inventory   HotelInventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)

    ratePlanId String?
    ratePlan   HotelRatePlan? @relation(fields: [ratePlanId], references: [id], onDelete: SetNull)

    userId String?
    user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

    bookingId String?
    booking   HotelBooking? @relation(fields: [bookingId], references: [id], onDelete: Cascade)

    quantity Int                 @default(1)
    status   InventoryLockStatus @default(locked)

    startTime  DateTime
    releasedAt DateTime?
    endTime    DateTime
    expiresAt  DateTime
    createdAt  DateTime  @default(now())

    @@index([inventoryId])
    @@index([expiresAt])
}