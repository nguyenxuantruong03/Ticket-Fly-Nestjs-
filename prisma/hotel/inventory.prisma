model HotelInventory {
    id String @id @default(cuid())

    hotelId String
    hotel   Hotel  @relation(fields: [hotelId], references: [id], onDelete: Cascade)

    roomTypeId String
    roomType   HotelRoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)

    availability HotelAvailability?
    ratePlans    HotelRatePlan[]
    locks        HotelInventoryLock[]

    bookingRooms HotelBookingRoom[]

    @@unique([hotelId, roomTypeId])
    @@index([hotelId])
}

model HotelAvailability {
    id String @id @default(cuid())

    inventoryId String         @unique
    inventory   HotelInventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)

    isAvailable    Boolean
    availableRooms Int?

    lastUpdated DateTime?

    calendar HotelAvailabilityCalendar[]
}

model HotelAvailabilityCalendar {
    id String @id @default(cuid())

    availabilityId String
    availability   HotelAvailability @relation(fields: [availabilityId], references: [id], onDelete: Cascade)

    date              DateTime
    available         Boolean
    remainingRooms    Int?
    priceOverride     Float?
    stopSell          Boolean?
    /**
     * cuối tuần phải ở tối thiểu 2 đêm
     * không được check-in vào ngày lễ
     * không được check-out vào một số ngày
     */
    minimumStay       Int?
    closedToArrival   Boolean?
    closedToDeparture Boolean?

    @@unique([availabilityId, date])
    @@index([date])
}

model HotelInventoryLock {
    id String @id @default(cuid())

    inventoryId String
    inventory   HotelInventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)

    ratePlanId String?
    ratePlan   HotelRatePlan? @relation(fields: [ratePlanId], references: [id], onDelete: SetNull)

    userId String?
    user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

    bookingId String?
    booking   HotelBooking? @relation(fields: [bookingId], references: [id], onDelete: Cascade)

    quantity Int                 @default(1)
    status   InventoryLockStatus @default(locked)

    startTime DateTime
    releasedAt DateTime?
    endTime DateTime
    expiresAt DateTime
    createdAt DateTime @default(now())

    @@index([inventoryId])
    @@index([expiresAt])
}

model HotelRatePlan {
    id String @id @default(cuid())

    inventoryId String
    inventory   HotelInventory       @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
    locks       HotelInventoryLock[]
    name        String

    description String?

    type     HotelRatePlanType
    code     String?
    mealPlan MealPlan?
    policies HotelPolicies?

    refundable Boolean @default(false)

    cancellationPolicy HotelRatePlanCancellation?

    price HotelRoomPrice?

    active Boolean @default(true)

    createdAt DateTime @default(now())

    updatedAt DateTime @updatedAt

    @@index([inventoryId])
}

model HotelRatePlanCancellation {
    id String @id @default(cuid())

    ratePlanId String        @unique
    ratePlan   HotelRatePlan @relation(fields: [ratePlanId], references: [id], onDelete: Cascade)

    freeCancellation Boolean @default(false)
    beforeHours      Int?

    cancellationFee Float?
}
