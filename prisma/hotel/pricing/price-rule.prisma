model HotelRoomPriceRule {
    id String @id @default(cuid())

    priceId String
    price   HotelRoomPrice @relation(fields: [priceId], references: [id], onDelete: Cascade)

    name String?

    type           HotelPriceRuleType
    adjustmentType HotelPriceAdjustmentType
    value          Float
    minimumNights  Int?
    maximumNights  Int?
    validFrom      DateTime?
    validTo        DateTime?
    daysOfWeek     WeekDay[]
    priority       Int                      @default(0)
    combinable     Boolean                  @default(false)
    active         Boolean                  @default(true)
    createdAt      DateTime                 @default(now())
    updatedAt      DateTime                 @updatedAt

    @@index([type])
    @@index([active])
    @@index([validFrom, validTo])
    @@index([priceId, active])
}
